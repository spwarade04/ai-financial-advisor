# AI Financial Advisor V2 - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Google Gemini API Configuration (Required for AI features)
# =============================================================================
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=models/gemini-2.0-flash

# =============================================================================
# Flask Configuration
# =============================================================================
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000

# Generate a strong secret key for production
# Use: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# =============================================================================
# JWT Authentication Configuration
# =============================================================================
# Generate a strong JWT secret key
# Use: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ACCESS_TOKEN_EXPIRES=86400

# =============================================================================
# Database Configuration
# =============================================================================
# For SQLite (Development):
DATABASE_URL=sqlite:///ai_financial_advisor.db

# For PostgreSQL (Production):
# DATABASE_URL=postgresql://username:password@localhost:5432/ai_financial_advisor

# =============================================================================
# Backend API URL (for frontend to connect)
# =============================================================================
BACKEND_API_URL=http://localhost:5000

# =============================================================================
# Streamlit Configuration
# =============================================================================
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# Optional: External Services
# =============================================================================
# SENTRY_DSN=your_sentry_dsn_here
# REDIS_URL=redis://localhost:6379/0
